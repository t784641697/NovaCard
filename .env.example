# 环境变量配置
# 复制此文件为 .env 并填写真实值，.env 不要提交到 git

# ── 服务配置 ──
PORT=3000
NODE_ENV=development

# ── JWT 认证 ──
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# ── vmcardio API ──
VMCARDIO_APP_ID=your_app_id
VMCARDIO_APP_SECRET=your_app_secret
# 沙箱环境
VMCARDIO_BASE_URL=https://sandbox-api.vmcardio.com
# 生产环境（上线后替换）
# VMCARDIO_BASE_URL=https://api.vmcardio.com

# RSA 密钥（实际使用时建议用文件路径，不要直接写在 .env 里）
# 平台公钥（用于加密发送给 vmcardio 的请求 content 字段）
VMCARDIO_PLATFORM_PUBLIC_KEY_PATH=./config/vmcardio_platform_public.pem
# 商户私钥（用于解密 vmcardio 返回的 data 字段）
VMCARDIO_MERCHANT_PRIVATE_KEY_PATH=./config/merchant_private.pem

# ── WebHook ──
WEBHOOK_SECRET=your-webhook-verify-secret

# ── 腾讯云短信 ──
# 在腾讯云控制台 -> 访问管理 -> API密钥 中获取
TENCENT_SMS_SECRET_ID=YOUR_SECRET_ID
TENCENT_SMS_SECRET_KEY=YOUR_SECRET_KEY
# 短信应用 SDKAppID（控制台 -> 短信 -> 应用管理）
TENCENT_SMS_SDK_APP_ID=1400000000
# 短信签名（需审核通过）
TENCENT_SMS_SIGN_NAME=XiuXiu Card
# 短信模板 ID（控制台 -> 短信 -> 正文模板管理，模板内容示例：）
# "您的{1}验证码为{2}，{3}分钟内有效，请勿泄露。如非本人操作，请忽略。"
TENCENT_SMS_TPL_REGISTER=0000001
TENCENT_SMS_TPL_LOGIN=0000002
TENCENT_SMS_TPL_RESET=0000003
# 地域（境内用 ap-guangzhou，境外用 ap-singapore）
TENCENT_SMS_REGION=ap-guangzhou

# ── 数据库（可选，后续接入）──
# DATABASE_URL=postgresql://user:pass@localhost:5432/vcc_hub
